# ---- edu-sharing Repository ----
EDU_REPO_BASE_URL=https://redaktion.openeduhub.net
EDU_REPO_API=https://redaktion.openeduhub.net/edu-sharing/rest

# Gast-Account (für anonyme Ideen-Einreichungen)
EDU_GUEST_USER=WLO-Upload
EDU_GUEST_PASS=wlo#upload!20
EDU_GUEST_INBOX_ID=21144164-30c0-4c01-ae16-264452197063

# Wurzel-Sammlung der Ideendatenbank (aktuelle HackathOERn-Ideensammlung)
IDEENDB_ROOT_COLLECTION_ID=4197d4d2-c700-400c-97d4-d2c700900c68

# ---- FastAPI ----
APP_HOST=127.0.0.1
APP_PORT=8000
# CORS: strikt nur die hier gelisteten Origins. Für Dev-Server explizit
# eintragen (z.B. http://localhost:4201). Kein Wildcard-Fallback.
APP_CORS_ORIGINS=http://localhost:4200,https://wp-test.wirlernenonline.de

# SQLite-Cache
SQLITE_PATH=./data/ideendb.sqlite
SYNC_INTERVAL_SECONDS=300

# ---- Backup (App-DB) ----
# Auto-Backup als ZIP mit der SQLite-DB (KEINE Konfig/Secrets im Backup).
# Pfad neben der App, Retention behält die letzten N Backups.
BACKUP_ENABLED=true
BACKUP_DIR=./data/backups
BACKUP_INTERVAL_HOURS=24
BACKUP_KEEP=3

# ---- Moderation ----
# Mitglieder dieser edu-sharing-Gruppe haben Mod-Rechte (Taxonomie-CRUD, Inbox,
# Verschieben). Gruppe muss einmalig im Repository angelegt werden.
MODERATION_GROUP=GROUP_HackathOERn_Moderation
# Komma-separiert. Mitglieder dieser Gruppen werden als Moderator anerkannt.
MODERATION_FALLBACK_GROUPS=GROUP_ALFRESCO_ADMINISTRATORS
# Komma-Liste der Usernames, die unabhängig von der Gruppe immer Mod-Status
# haben (Bootstrap, bevor die Mod-Gruppe existiert / befüllt ist).
MODERATION_BOOTSTRAP_USERS=

# ---- KI (optional, später) ----
# LLM_PROVIDER=b-api-academiccloud
# LLM_BASE_URL=https://b-api.prod.openeduhub.net/api/v1/llm/academiccloud
# LLM_API_KEY=
# LLM_MODEL=qwen3-coder-30b
