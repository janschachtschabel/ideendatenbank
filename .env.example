# ────────────────────────────────────────────────────────────────────
# HackathOERn Ideendatenbank — Konfigurations-Vorlage
#
# Kopiere diese Datei nach `.env` und ersetze die <Platzhalter>.
# Pflichtfelder sind klar markiert — alles andere hat sinnvolle Defaults.
#
# WICHTIG: `.env` gehört NIE ins Git-Repo. Auch nicht in Backups —
# die App schließt Konfig/Secrets bewusst aus ZIP-Backups aus.
# ────────────────────────────────────────────────────────────────────

# ============== PFLICHT ============================================

# ---- edu-sharing Gast-Account ----
# Service-Account (kein Personen-Login), der die Inbox-Sammlung für
# anonyme Einreichungen schreiben darf. WLO-Redaktion stellt ihn bereit
# — bitte direkt anfragen, NICHT raten.
EDU_GUEST_USER=<von-WLO-erhalten>
EDU_GUEST_PASS=<von-WLO-erhalten>

# ---- CORS-Origins ----
# Komma-Liste der Domains, die die App per Browser aufrufen dürfen.
# Bei Single-Origin-Setup (Backend + Frontend gleicher Host) reicht
# der eigene Host. Für Cross-Origin-Embeds zusätzlich die Drittseiten.
APP_CORS_ORIGINS=https://ideen.example.de

# ============== Sinnvolle Defaults =================================

# ---- edu-sharing Repository ----
EDU_REPO_BASE_URL=https://redaktion.openeduhub.net
EDU_REPO_API=https://redaktion.openeduhub.net/edu-sharing/rest

# Inbox-Sammlung für anonyme Submits (HackathOERn-Postfach).
# Nur ändern, wenn du eine eigene Inbox angelegt hast.
EDU_GUEST_INBOX_ID=21144164-30c0-4c01-ae16-264452197063

# Wurzel-Sammlung der Ideendatenbank — alle Herausforderungen
# liegen darunter. Default = aktuelle HackathOERn-Ideensammlung.
IDEENDB_ROOT_COLLECTION_ID=4197d4d2-c700-400c-97d4-d2c700900c68

# ---- FastAPI ----
APP_HOST=127.0.0.1
APP_PORT=8000

# SQLite-Cache + Sync-Intervall (Sekunden). 300 = alle 5 Min.
# Im Docker-Container ist der Pfad /data/ideendb.sqlite (Volume).
SQLITE_PATH=./data/ideendb.sqlite
SYNC_INTERVAL_SECONDS=300

# ---- Backup (App-DB) ----
# Auto-Backup als ZIP der SQLite-DB (KEINE Konfig/Secrets im Backup).
# Auto-Restore beim Erststart: wenn die DB fehlt aber Backups liegen,
# wird das jüngste vor `init_db` zurückgespielt.
BACKUP_ENABLED=true
BACKUP_DIR=./data/backups
BACKUP_INTERVAL_HOURS=24
BACKUP_KEEP=3

# ---- Moderation ----
# Komma-Liste von edu-sharing-Gruppen, deren Mitglieder Mod-Rechte
# erhalten (Taxonomie-CRUD, Inbox, Verschieben, Backup-Verwaltung,
# Versteckt-Verwaltung). Default = globale ES-Admins; weitere Gruppen
# können angehängt werden.
MODERATION_FALLBACK_GROUPS=GROUP_ALFRESCO_ADMINISTRATORS
# Komma-Liste von Usernames, die unabhängig von der Gruppe Mod-Status
# bekommen. Bootstrap, bevor die Mod-Gruppe befüllt ist — danach besser
# leer lassen, damit Rechteentzug ein-Klick-Operation in edu-sharing
# bleibt.
MODERATION_BOOTSTRAP_USERS=

# ============== Optional ===========================================

# ---- KI (nicht eingebaut, reserviert) ----
# LLM_PROVIDER=b-api-academiccloud
# LLM_BASE_URL=https://b-api.prod.openeduhub.net/api/v1/llm/academiccloud
# LLM_API_KEY=
# LLM_MODEL=qwen3-coder-30b
